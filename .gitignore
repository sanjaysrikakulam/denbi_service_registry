# =============================================================================
# Secrets — never commit these
# =============================================================================
.env
.env.local
.env.production
.env.*.local
.secrets.toml
*.pem
*.key

# .env.example IS committed — it documents required variables
# The patterns above are specific enough that .env.example is not matched


# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-selfcheck.json


# =============================================================================
# Django
# =============================================================================
staticfiles/
mediafiles/
*.sqlite3


# =============================================================================
# Testing / coverage
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.mypy_cache/
junit.xml
test-results/


# =============================================================================
# Celery runtime state
# =============================================================================
celerybeat-schedule
celerybeat-schedule.*
celerybeat.pid


# =============================================================================
# MkDocs build output
# =============================================================================
site/


# =============================================================================
# Docker / infrastructure
# =============================================================================
nginx/ssl/


# =============================================================================
# IDE and editor artifacts
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*.swn
*~


# =============================================================================
# OS artifacts
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini


# =============================================================================
# Node (in case tooling is added in future)
# =============================================================================
node_modules/
