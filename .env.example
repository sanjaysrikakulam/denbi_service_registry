# =============================================================================
# de.NBI Service Registry — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
# All variables are plain environment variables — no prefixes, no nesting.
# The same names are used by Docker Compose and by Django.
#
# Lines starting with # are comments.
# Lines with a value set (e.g. FOO=bar) are the defaults used by the app.
# Lines commented out (e.g. # FOO=bar) show the format but are not active.
# =============================================================================


# =============================================================================
# REQUIRED — startup fails without these
# =============================================================================

SECRET_KEY=change-me-generate-with-python-manage.py-generate-secret-key
DB_PASSWORD=change-me
REDIS_PASSWORD=change-me


# =============================================================================
# Django core
# =============================================================================

DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,service-registry.bi.denbi.de

# Timezone used for all datetime display and Celery beat schedules.
TIME_ZONE=Europe/Berlin


# =============================================================================
# Database (PostgreSQL)
# =============================================================================

DB_NAME=denbi_registry
DB_USER=denbi
DB_HOST=db          # Docker Compose service name in dev; real hostname in prod
DB_PORT=5432


# =============================================================================
# Redis
# =============================================================================

REDIS_HOST=redis    # Docker Compose service name in dev; real hostname in prod
REDIS_PORT=6379


# =============================================================================
# Reverse proxy / real IP
# =============================================================================

# IP address (or comma-separated list / CIDR range) of the nginx reverse proxy
# that forwards requests to Gunicorn.  Gunicorn only rewrites REMOTE_ADDR from
# X-Forwarded-For when the connection comes from a trusted IP.
# Without this, Django records the proxy's IP instead of the real client IP.
#
# Same machine (loopback):  FORWARDED_ALLOW_IPS=127.0.0.1
# Separate nginx server:    FORWARDED_ALLOW_IPS=192.168.232.10
# Internal subnet:          FORWARDED_ALLOW_IPS=192.168.232.0/24
FORWARDED_ALLOW_IPS=127.0.0.1


# =============================================================================
# Security
# =============================================================================

# HSTS max-age in seconds (default: 1 year).  Set to 0 to disable HSTS.
HSTS_SECONDS=31536000

# Force HTTP→HTTPS redirect at the Django layer.  Usually handled by nginx;
# disable here if nginx already redirects and you want to avoid double redirects.
SECURE_SSL_REDIRECT=true

# Mark session and CSRF cookies as Secure (HTTPS-only).  Should be true in prod.
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# Session lifetime in seconds (default: 3600 = 1 hour).
SESSION_COOKIE_AGE=3600


# =============================================================================
# Admin brute-force protection (django-axes)
# =============================================================================

# Number of failed login attempts before lockout (default: 5).
AXES_FAILURE_LIMIT=5

# Lockout duration in minutes (default: 30).
AXES_COOLOFF_MINUTES=30


# =============================================================================
# Rate limiting
# =============================================================================

# Format: <count>/<period>  where period is s/m/h/d.
# Applied to the registration form, update form, and REST API respectively.
RATE_LIMIT_SUBMIT=10/h
RATE_LIMIT_UPDATE=20/h
RATE_LIMIT_API=60/m


# =============================================================================
# Email (SMTP credentials)
# =============================================================================

# In development, Django prints emails to the console (default).
# In production, switch to the SMTP backend:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

EMAIL_HOST=smtp.example.org
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Overrides [email] from_address in site.toml if set.
EMAIL_FROM=no-reply@denbi.de

# CC address added to every submission notification email (optional).
# SUBMISSION_NOTIFY_CC=admin@denbi.de

# Override the notification recipient for testing (sends all emails here instead).
# SUBMISSION_NOTIFY_OVERRIDE=test-inbox@denbi.de


# =============================================================================
# REST API
# =============================================================================

# Default and maximum page sizes for paginated list endpoints.
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

# CORS: comma-separated list of allowed origins for cross-origin API requests.
# Leave empty to disallow all cross-origin requests (safe default).
# Example: CORS_ALLOWED_ORIGINS=https://app.example.org,https://partner.org
CORS_ALLOWED_ORIGINS=

# Allow cookies / credentials in CORS requests (default: false).
CORS_ALLOW_CREDENTIALS=false


# =============================================================================
# API keys
# =============================================================================

# Entropy bytes for generated API keys (default: 48 → 64-char URL-safe token).
# Increase for higher security; decrease only if key length causes issues.
API_KEY_ENTROPY_BYTES=48

# Hash algorithm for storing API key hashes (default: sha256).
# Only change if you have a specific compliance requirement.
API_KEY_HASH_ALGORITHM=sha256


# =============================================================================
# EDAM ontology sync
# =============================================================================

# URL of the EDAM OWL file fetched by `manage.py sync_edam`.
# Pin a specific release: https://edamontology.org/EDAM_1.25.owl
# Air-gapped servers: /app/EDAM.owl
EDAM_OWL_URL=https://edamontology.org/EDAM_stable.owl


# =============================================================================
# Branding overrides
# =============================================================================

# These can also be set in config/site.toml.  Env vars take precedence.

# Admin URL prefix (obfuscates the admin URL; not a security boundary on its own).
# ADMIN_URL_PREFIX=admin-denbi

# Logo URL shown in the navbar.  Leave empty to auto-detect static/img/logo.*.
# LOGO_URL=/static/img/logo.svg
# LOGO_URL=https://www.example.org/img/logo.svg
LOGO_URL=


# =============================================================================
# Error tracking (Sentry)
# =============================================================================

# Leave empty to disable Sentry.
SENTRY_DSN=

# Fraction of transactions to send to Sentry for performance monitoring (0–1).
SENTRY_TRACES_SAMPLE_RATE=0.1
