# =============================================================================
# de.NBI Service Registry — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
# All variables are plain environment variables — no prefixes, no nesting.
# The same names are used by Docker Compose and by Django.
# =============================================================================

# --- Required (startup fails without these) ---------------------------------

SECRET_KEY=change-me-generate-with-python-manage.py-generate-secret-key
DB_PASSWORD=change-me
REDIS_PASSWORD=change-me

# --- Database ----------------------------------------------------------------

DB_NAME=denbi_registry
DB_USER=denbi
DB_HOST=db
DB_PORT=5432

# --- Redis -------------------------------------------------------------------

REDIS_HOST=redis
REDIS_PORT=6379

# --- Django ------------------------------------------------------------------

DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Email -------------------------------------------------------------------
# In development, emails print to the console (EMAIL_BACKEND default).
# In production, set EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

EMAIL_HOST=smtp.example.org
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=no-reply@denbi.de

# --- CAPTCHA (disabled by default when DEBUG=true) ---------------------------

HCAPTCHA_SECRET_KEY=
HCAPTCHA_SITEKEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_SITEKEY=

# --- Optional ----------------------------------------------------------------

SENTRY_DSN=
# ADMIN_URL_PREFIX is set in config/site.toml → [admin] url_prefix
# Override here only to change per-environment without editing site.toml:
# ADMIN_URL_PREFIX=admin-denbi

# --- EDAM Ontology sync URL --------------------------------------------------
# Change this to pin a specific EDAM release, e.g.:
#   https://edamontology.org/EDAM_1.25.owl
# Or point to a local file for air-gapped servers:
#   EDAM_OWL_URL=/app/EDAM.owl
EDAM_OWL_URL=https://edamontology.org/EDAM_stable.owl

# --- Logo --------------------------------------------------------------------
# URL of your logo image shown in the navbar.
# Leave empty to auto-detect static/img/logo.{png,svg,jpg}.
# Examples:
#   LOGO_URL=/static/img/logo.png
#   LOGO_URL=https://www.denbi.de/images/logos/denbi-logo.png
LOGO_URL=
